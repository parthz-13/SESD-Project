// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum UserRole {
  ADMIN
  LIBRARIAN
  MEMBER
}

enum MembershipType {
  STANDARD
  PREMIUM
  STUDENT
}

enum BorrowingStatus {
  ISSUED
  RETURNED
  OVERDUE
}

enum ReservationStatus {
  PENDING
  FULFILLED
  CANCELLED
  EXPIRED
}

enum FineStatus {
  UNPAID
  PAID
}

enum NotificationType {
  DUE_REMINDER
  OVERDUE_ALERT
  AVAILABILITY
  GENERAL
}

// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MEMBER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member        Member?
  librarian     Librarian?
  notifications Notification[]
}

model Member {
  id                String         @id @default(cuid())
  userId            Int            @unique
  membershipNumber  String         @unique
  membershipType    MembershipType @default(STANDARD)
  membershipExpiry  DateTime
  outstandingFine   Float          @default(0)
  createdAt         DateTime       @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrowings   Borrowing[]
  reservations Reservation[]
  fines        Fine[]
}

model Librarian {
  id           String   @id @default(cuid())
  userId       Int      @unique
  employeeCode String   @unique
  createdAt    DateTime @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrowings Borrowing[] @relation("IssuedByLibrarian")
}

model Book {
  id              Int      @id @default(autoincrement())
  title           String
  isbn            String   @unique
  publisher       String
  year            Int
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  description     String?
  coverImage      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authors      BookAuthor[]
  categories   BookCategory[]
  borrowings   Borrowing[]
  reservations Reservation[]
}

model Author {
  id    Int    @id @default(autoincrement())
  name  String
  bio   String?

  books BookAuthor[]
}

model Category {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?

  books BookCategory[]
}

model BookAuthor {
  bookId   Int
  authorId Int

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([bookId, authorId])
}

model BookCategory {
  bookId     Int
  categoryId Int

  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([bookId, categoryId])
}

model Borrowing {
  id          Int             @id @default(autoincrement())
  memberId    String
  bookId      Int
  issuedBy    String
  issueDate   DateTime        @default(now())
  dueDate     DateTime
  returnDate  DateTime?
  status      BorrowingStatus @default(ISSUED)
  createdAt   DateTime        @default(now())

  member    Member    @relation(fields: [memberId], references: [id])
  book      Book      @relation(fields: [bookId], references: [id])
  librarian Librarian @relation("IssuedByLibrarian", fields: [issuedBy], references: [id])
  fine      Fine?
}

model Reservation {
  id          Int               @id @default(autoincrement())
  memberId    String
  bookId      Int
  reservedOn  DateTime          @default(now())
  expiryDate  DateTime
  status      ReservationStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  member Member @relation(fields: [memberId], references: [id])
  book   Book   @relation(fields: [bookId], references: [id])
}

model Fine {
  id          Int        @id @default(autoincrement())
  borrowingId Int        @unique
  memberId    String
  amount      Float
  status      FineStatus @default(UNPAID)
  paidOn      DateTime?
  createdAt   DateTime   @default(now())

  borrowing Borrowing @relation(fields: [borrowingId], references: [id])
  member    Member    @relation(fields: [memberId], references: [id])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
